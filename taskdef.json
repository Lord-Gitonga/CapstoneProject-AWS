{
  "family": "myapp-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "myapp-container",
      "image": "422653419447.dkr.ecr.eu-north-1.amazonaws.com/myapp-repo:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::422653419447:role/RoleForECS"
}